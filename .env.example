# ─── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Supabase (Auth + Database) ──────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://spg_user:spg_pass@localhost:5432/spg_db
DIRECT_URL=postgresql://spg_user:spg_pass@localhost:5432/spg_db

# DrizzleORM (apps/web — TypeScript)
NEXT_PUBLIC_DB_HOST=localhost
DB_PORT=5432
DB_NAME=spg_db
DB_USER=spg_user
DB_PASSWORD=spg_pass

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── DocuForge (PDF export) ─────────────────────────────────
DOCUFORGE_API_KEY=df_...

# ─── Resend (email) ─────────────────────────────────────────
RESEND_API_KEY=re_...
EMAIL_FROM=propuestas@tudominio.com

# ─── Stripe ─────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Apitally (API monitoring) ───────────────────────────────
APITALLY_CLIENT_ID=...

# ─── App ────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:8000
ENVIRONMENT=development
