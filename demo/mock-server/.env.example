# ============================================================
# Smart Proposal Generator — Environment Variables
# ============================================================
# Copy this file to apps/web/.env.local (Next.js) and apps/api/.env (FastAPI)
# Variables marked [MOCKED] are handled by the mock server — not needed for offline demo
# Variables marked [REQUIRED] are needed for full production functionality

# --- Auth (Supabase) [MOCKED in offline demo] ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI (Anthropic) [MOCKED — mock server streams fake proposals] ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Database (Supabase/PostgreSQL) [MOCKED — mock server uses in-memory storage] ---
DATABASE_URL=postgresql+asyncpg://spg_user:spg_pass@localhost:5432/spg_db
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Billing (Stripe) [MOCKED — export buttons show success toast] ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# --- Email (Resend) [MOCKED] ---
RESEND_API_KEY=re_...

# --- PDF Export (DocuForge) [MOCKED] ---
DOCUFORGE_API_KEY=dfe_...

# --- Mock server endpoint (for offline demo) ---
NEXT_PUBLIC_MOCK_API_URL=http://localhost:3001
