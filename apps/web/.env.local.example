# Supabase (Auth + Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (AI via @ai-sdk/openai + baseURL openrouter.ai)
# Used for proposal generation (claude-3-5-haiku) and URL analysis
OPENROUTER_API_KEY=sk-or-...

# Backend API (FastAPI — for DOCX export)
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Database — Supabase Transaction Pooler (pgBouncer, puerto 6543)
# Obtener en: Supabase Dashboard → Settings → Database → Connection string → Transaction
# El parámetro ?pgbouncer=true deshabilita prepared statements (requerido para Transaction mode)
DATABASE_URL=postgresql://postgres.xxxx:[PASSWORD]@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (transactional email — optional, falls back to Ethereal in dev/missing key)
RESEND_API_KEY=re_...

# PDF Export — DocuForge REST API
# Obtener en: https://getdocuforge.dev
DOCUFORGE_API_KEY=df_...

# Rate Limiting — Upstash Redis (global, cross-instance)
# Obtener en: https://console.upstash.com → crear database → REST API
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxx
