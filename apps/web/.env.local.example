# Supabase (Auth + Database)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenRouter (AI via @ai-sdk/openai + baseURL openrouter.ai)
# Used for proposal generation (claude-3-5-sonnet) and URL analysis (claude-3-5-haiku)
OPENROUTER_API_KEY=sk-or-...

# Backend API (FastAPI — for DOCX export)
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://localhost:8000

# Database (DrizzleORM — connect via Supabase pooler or direct Postgres)
DATABASE_URL=postgresql://spg_user:spg_pass@localhost:5432/spg_db

# Stripe Billing
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Resend (transactional email — optional, falls back to Ethereal in dev/missing key)
RESEND_API_KEY=re_...

# PDF Export — now handled by Puppeteer + @sparticuz/chromium (no external API key needed)
# DOCUFORGE_API_KEY=... (removed — no longer used)
